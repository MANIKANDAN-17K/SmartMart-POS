<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.supermarketpos.controller.ProductController"
            stylesheets="@../css/dashboard.css"
            prefWidth="1280" prefHeight="800">

    <!-- ── LEFT SIDEBAR ────────────────────────────────────────────────── -->
    <left>
        <VBox styleClass="sidebar">
            <HBox styleClass="logo-container">
                <Label text="🛒" styleClass="logo-icon"/>
                <Label text="SmartMart" styleClass="logo-text-brand"/>
                <Label text="POS" styleClass="logo-text-pos"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="sidebar-scroll">
                <VBox spacing="4.0">
                    <padding><Insets top="10.0" right="12.0" bottom="10.0" left="12.0"/></padding>

                    <Button fx:id="btnDashboardNav" text="🏠  Dashboard" onAction="#onDashboard" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnNewBillNav" text="🛒  New Bill" onAction="#onNewBill" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnProductsNav" text="🏷️  Products" onAction="#onProducts" styleClass="sidebar-nav-button, active" maxWidth="Infinity"/>
                    <Button fx:id="btnInventoryNav" text="📦  Inventory" onAction="#onInventory" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnPurchasesNav" text="🛍️  Purchases" onAction="#onPurchases" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnCustomersNav" text="👥  Customers" onAction="#onCustomersNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnSuppliersNav" text="🚚  Suppliers" onAction="#onSuppliersNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnReportsNav" text="📊  Reports" onAction="#onReports" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnSettingsNav" text="⚙️  Settings" onAction="#onSettings" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnUsersNav" text="👤  Users" onAction="#onUsersNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnBackupNav" text="💾  Backup" onAction="#onBackupNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                </VBox>
            </ScrollPane>

            <VBox>
                <padding><Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/></padding>
                <HBox styleClass="sidebar-user-card" alignment="CENTER_LEFT">
                    <Label text="👤" styleClass="avatar-circle"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="loggedUserLabel" text="admin" styleClass="user-name-text"/>
                        <Label fx:id="roleLabel" text="Administrator" styleClass="user-role-text"/>
                        <Label text="🟢 Online" styleClass="status-online"/>
                    </VBox>
                    <Button fx:id="logoutButton" text="🚪 Logout" onAction="#onLogout" styleClass="btn-logout-sidebar"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- ── TOP HEADER BAR ──────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="15.0">
            <Button text="🛒" styleClass="menu-toggle-btn"/>

            <HBox styleClass="search-box">
                <Label text="🔍 " style="-fx-text-fill: #94a3b8;"/>
                <TextField fx:id="searchField" promptText="Search product by name / barcode / SKU..." styleClass="search-field" onAction="#handleSearch" HBox.hgrow="ALWAYS"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="dateLabel" text="19 Jul 2026 Sunday" styleClass="header-info-label"/>
            <Label text="|" styleClass="header-info-label" style="-fx-text-fill: #cbd5e1;"/>
            <Label fx:id="currentTimeLabel" text="01:39 PM" styleClass="header-info-label"/>
            <Button fx:id="refreshButton" text="🔄" onAction="#handleRefresh" styleClass="menu-toggle-btn"/>
            <Button text="🚪 Logout" onAction="#onLogout" styleClass="btn-logout-sidebar"/>
        </HBox>
    </top>

    <!-- ── CENTER CONTENT ─────────────────────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="sidebar-scroll">
            <VBox styleClass="dashboard-content">

                <!-- Header Title -->
                <VBox spacing="4.0">
                    <Label text="Product Catalog Management" styleClass="welcome-title"/>
                    <Label text="Manage supermarket product items, barcodes, pricing, tax rates, and category assignments." styleClass="welcome-subtitle"/>
                </VBox>

                <!-- KPI Summary Cards -->
                <HBox spacing="16.0">
                    <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <Label text="🏷️" styleClass="kpi-icon-box, kpi-icon-products"/>
                        <VBox spacing="2">
                            <Label text="Total Catalog Items" styleClass="kpi-title"/>
                            <Label fx:id="lblTotalProducts" text="0" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <Label text="🟢" styleClass="kpi-icon-box, kpi-icon-sales"/>
                        <VBox spacing="2">
                            <Label text="Active Products" styleClass="kpi-title"/>
                            <Label fx:id="lblActiveProducts" text="0" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <Label text="⚠️" styleClass="kpi-icon-box, kpi-icon-customers"/>
                        <VBox spacing="2">
                            <Label text="Low Stock Items" styleClass="kpi-title"/>
                            <Label fx:id="lblLowStockProducts" text="0" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>
                </HBox>

                <!-- Main Content Split Pane -->
                <HBox spacing="16.0">

                    <!-- Product Table Area -->
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" prefWidth="720">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Product Directory" styleClass="card-header-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="🔍 Search" onAction="#handleSearch" styleClass="btn-secondary"/>
                            <Button text="🔄 Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
                        </HBox>

                        <TableView fx:id="productTable" prefHeight="480" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="nameColumn" text="Product Name" prefWidth="200.0"/>
                                <TableColumn fx:id="barcodeColumn" text="Barcode" prefWidth="120.0"/>
                                <TableColumn fx:id="skuColumn" text="SKU" prefWidth="100.0"/>
                                <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120.0"/>
                                <TableColumn fx:id="sellingPriceColumn" text="Price (₹)" prefWidth="100.0"/>
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="90.0"/>
                            </columns>
                            <placeholder><Label text="No products found in catalog."/></placeholder>
                        </TableView>
                    </VBox>

                    <!-- Product Detail & Form Card -->
                    <VBox styleClass="content-card" prefWidth="400">
                        <Label text="Product Information" styleClass="card-header-title"/>

                        <VBox spacing="8.0">
                            <VBox spacing="4">
                                <Label text="Product Name *" styleClass="form-label"/>
                                <TextField fx:id="nameField" promptText="Item name (e.g. Amul Butter 500g)"/>
                            </VBox>

                            <HBox spacing="8">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Barcode" styleClass="form-label"/>
                                    <HBox spacing="4" alignment="CENTER_LEFT">
                                        <TextField fx:id="barcodeField" promptText="Barcode" HBox.hgrow="ALWAYS"/>
                                        <Button text="⚡" onAction="#handleGenerateBarcode" styleClass="btn-secondary" tooltip="$null"/>
                                    </HBox>
                                </VBox>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="SKU Code" styleClass="form-label"/>
                                    <TextField fx:id="skuField" promptText="SKU"/>
                                </VBox>
                            </HBox>

                            <VBox spacing="4">
                                <Label text="Category *" styleClass="form-label"/>
                                <ComboBox fx:id="categoryDropdown" promptText="Select Category" maxWidth="Infinity"/>
                            </VBox>

                            <HBox spacing="8">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Cost Price (₹)" styleClass="form-label"/>
                                    <TextField fx:id="costPriceField" promptText="0.00"/>
                                </VBox>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Selling Price (₹) *" styleClass="form-label"/>
                                    <TextField fx:id="sellingPriceField" promptText="0.00"/>
                                </VBox>
                                <VBox spacing="4" prefWidth="80">
                                    <Label text="GST (%)" styleClass="form-label"/>
                                    <TextField fx:id="gstField" promptText="18"/>
                                </VBox>
                            </HBox>

                            <!-- Image Preview Area -->
                            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #f8fafc; -fx-padding: 8; -fx-background-radius: 8px;">
                                <ImageView fx:id="previewImage" fitWidth="64" fitHeight="64" preserveRatio="true"/>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Product Image" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                                    <Button fx:id="uploadImageButton" text="📷 Upload Image" onAction="#handleUploadImage" styleClass="btn-secondary"/>
                                </VBox>
                            </HBox>

                            <Separator style="-fx-padding: 4 0;"/>

                            <HBox spacing="8">
                                <Button fx:id="saveButton" text="Save Product" onAction="#handleSave" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Button fx:id="updateButton" text="Update" onAction="#handleUpdate" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            </HBox>

                            <HBox spacing="8">
                                <Button fx:id="activateButton" text="Activate" onAction="#handleActivate" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Button fx:id="deactivateButton" text="Deactivate" onAction="#handleDeactivate" styleClass="btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            </HBox>

                            <Button fx:id="clearButton" text="Clear Form" onAction="#handleClear" styleClass="btn-secondary" maxWidth="Infinity"/>
                        </VBox>
                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ── FOOTER BAR ──────────────────────────────────────────────────── -->
    <bottom>
        <HBox styleClass="footer-bar" alignment="CENTER_LEFT">
            <Label text="SmartMart POS v1.0.0 — Product Catalog Module" styleClass="footer-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="© 2026 SmartMart POS. All rights reserved." styleClass="footer-text"/>
        </HBox>
    </bottom>
</BorderPane>