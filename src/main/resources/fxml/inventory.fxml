<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.supermarketpos.controller.InventoryController"
            stylesheets="@../css/dashboard.css"
            prefWidth="1280" prefHeight="800">

    <!-- ── LEFT SIDEBAR ────────────────────────────────────────────────── -->
    <left>
        <VBox styleClass="sidebar">
            <HBox styleClass="logo-container">
                <Label text="🛒" styleClass="logo-icon"/>
                <Label text="SmartMart" styleClass="logo-text-brand"/>
                <Label text="POS" styleClass="logo-text-pos"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="sidebar-scroll">
                <VBox spacing="4.0">
                    <padding><Insets top="10.0" right="12.0" bottom="10.0" left="12.0"/></padding>

                    <Button fx:id="btnDashboardNav" text="🏠  Dashboard" onAction="#onDashboard" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnNewBillNav" text="🛒  New Bill" onAction="#onNewBill" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnProductsNav" text="🏷️  Products" onAction="#onProducts" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnInventoryNav" text="📦  Inventory" onAction="#onInventory" styleClass="sidebar-nav-button, active" maxWidth="Infinity"/>
                    <Button fx:id="btnPurchasesNav" text="🛍️  Purchases" onAction="#onPurchases" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnCustomersNav" text="👥  Customers" onAction="#onCustomersNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnSuppliersNav" text="🚚  Suppliers" onAction="#onSuppliersNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnReportsNav" text="📊  Reports" onAction="#onReports" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnSettingsNav" text="⚙️  Settings" onAction="#onSettings" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnUsersNav" text="👤  Users" onAction="#onUsersNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnBackupNav" text="💾  Backup" onAction="#onBackupNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                </VBox>
            </ScrollPane>

            <VBox>
                <padding><Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/></padding>
                <HBox styleClass="sidebar-user-card" alignment="CENTER_LEFT">
                    <Label text="👤" styleClass="avatar-circle"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="loggedUserLabel" text="admin" styleClass="user-name-text"/>
                        <Label fx:id="roleLabel" text="Administrator" styleClass="user-role-text"/>
                        <Label text="🟢 Online" styleClass="status-online"/>
                    </VBox>
                    <Button fx:id="logoutButton" text="🚪 Logout" onAction="#onLogout" styleClass="btn-logout-sidebar"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- ── TOP HEADER BAR ──────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="15.0">
            <Button text="🛒" styleClass="menu-toggle-btn"/>

            <HBox styleClass="search-box">
                <Label text="🔍 " style="-fx-text-fill: #94a3b8;"/>
                <TextField fx:id="searchField" promptText="Search stock by product name / barcode / SKU..." styleClass="search-field" onAction="#handleSearch" HBox.hgrow="ALWAYS"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="dateLabel" text="19 Jul 2026 Sunday" styleClass="header-info-label"/>
            <Label text="|" styleClass="header-info-label" style="-fx-text-fill: #cbd5e1;"/>
            <Label fx:id="currentTimeLabel" text="01:39 PM" styleClass="header-info-label"/>
            <Button fx:id="refreshButton" text="🔄" onAction="#handleResetFilters" styleClass="menu-toggle-btn"/>
            <Button text="🚪 Logout" onAction="#onLogout" styleClass="btn-logout-sidebar"/>
        </HBox>
    </top>

    <!-- ── CENTER CONTENT ─────────────────────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="sidebar-scroll">
            <VBox styleClass="dashboard-content">

                <!-- Header Title -->
                <VBox spacing="4.0">
                    <Label text="Inventory &amp; Stock Control" styleClass="welcome-title"/>
                    <Label text="Track stock levels, perform stock adjustments, monitor reorder alerts, and view movement logs." styleClass="welcome-subtitle"/>
                </VBox>

                <!-- KPI Summary Cards -->
                <HBox spacing="16.0">
                    <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <Label text="📦" styleClass="kpi-icon-box, kpi-icon-products"/>
                        <VBox spacing="2">
                            <Label text="Total Catalog Items" styleClass="kpi-title"/>
                            <Label fx:id="totalProductsLabel" text="0" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <Label text="📊" styleClass="kpi-icon-box, kpi-icon-sales"/>
                        <VBox spacing="2">
                            <Label text="Total Quantity in Stock" styleClass="kpi-title"/>
                            <Label fx:id="totalStockItemsLabel" text="0" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <Label text="⚠️" styleClass="kpi-icon-box, kpi-icon-customers"/>
                        <VBox spacing="2">
                            <Label text="Low Stock Warnings" styleClass="kpi-title"/>
                            <Label fx:id="lowStockCountLabel" text="0" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <Label text="🚨" styleClass="kpi-icon-box, kpi-icon-profit"/>
                        <VBox spacing="2">
                            <Label text="Out of Stock Items" styleClass="kpi-title"/>
                            <Label fx:id="outOfStockCountLabel" text="0" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>
                </HBox>

                <!-- Main Content Split Pane -->
                <HBox spacing="16.0">

                    <!-- Inventory Table Area -->
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" prefWidth="720">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Current Stock Levels" styleClass="card-header-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="categoryFilter" onAction="#handleCategoryFilterChange" promptText="Category"/>
                            <ComboBox fx:id="statusFilter" onAction="#handleStatusFilterChange" promptText="Stock Status"/>
                            <Button fx:id="searchButton" text="🔍 Search" onAction="#handleSearch" styleClass="btn-secondary"/>
                            <Button text="🔄 Reset" onAction="#handleResetFilters" styleClass="btn-secondary"/>
                        </HBox>

                        <TableView fx:id="inventoryTable" prefHeight="420" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="barcodeColumn" text="Barcode" prefWidth="110.0"/>
                                <TableColumn fx:id="skuColumn" text="SKU" prefWidth="90.0"/>
                                <TableColumn fx:id="nameColumn" text="Product Name" prefWidth="180.0"/>
                                <TableColumn fx:id="categoryColumn" text="Category" prefWidth="110.0"/>
                                <TableColumn fx:id="currentStockColumn" text="In Stock" prefWidth="80.0"/>
                                <TableColumn fx:id="minStockColumn" text="Min Stock" prefWidth="80.0"/>
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="90.0"/>
                                <TableColumn fx:id="lastUpdatedColumn" text="Last Stock Audit" prefWidth="120.0"/>
                            </columns>
                            <placeholder><Label text="No inventory records found."/></placeholder>
                        </TableView>
                    </VBox>

                    <!-- Stock Adjustment Panel Card -->
                    <VBox styleClass="content-card" prefWidth="380">
                        <Label text="Stock Level Adjustment" styleClass="card-header-title"/>

                        <VBox spacing="10.0">
                            <VBox spacing="4" style="-fx-background-color: #f8fafc; -fx-padding: 10; -fx-background-radius: 8px;">
                                <Label text="Selected Product:" styleClass="form-label"/>
                                <Label fx:id="selectedProductLabel" text="Select a product from table" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                <HBox spacing="6" style="-fx-padding: 4 0 0 0;">
                                    <Label text="Current Quantity:" styleClass="kpi-subtext"/>
                                    <Label fx:id="currentStockLabel" text="—" style="-fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                                </HBox>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Adjustment Type *" styleClass="form-label"/>
                                <ComboBox fx:id="adjustmentTypeDropdown" promptText="Select Adjustment Type" maxWidth="Infinity"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Adjustment Quantity *" styleClass="form-label"/>
                                <TextField fx:id="adjustmentQuantityField" promptText="Enter quantity (e.g. 10 or -5)"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Reason *" styleClass="form-label"/>
                                <TextField fx:id="reasonField" promptText="e.g. Received Purchase Order / Damaged Goods"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Remarks / Notes" styleClass="form-label"/>
                                <TextArea fx:id="remarksField" promptText="Additional remarks..." prefRowCount="3" wrapText="true"/>
                            </VBox>

                            <Separator style="-fx-padding: 4 0;"/>

                            <Button fx:id="adjustStockButton" text="Apply Stock Adjustment" onAction="#handleAdjustStock" styleClass="btn-primary" maxWidth="Infinity"/>
                        </VBox>
                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ── FOOTER BAR ──────────────────────────────────────────────────── -->
    <bottom>
        <HBox styleClass="footer-bar" alignment="CENTER_LEFT">
            <Label text="SmartMart POS v1.0.0 — Inventory Module" styleClass="footer-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="© 2026 SmartMart POS. All rights reserved." styleClass="footer-text"/>
        </HBox>
    </bottom>
</BorderPane>