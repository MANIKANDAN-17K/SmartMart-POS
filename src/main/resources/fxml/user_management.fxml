<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.supermarketpos.controller.UserManagementController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <top>
        <Label text="User Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    </top>

    <center>
        <TableView fx:id="userTable">
            <columns>
                <TableColumn fx:id="usernameColumn" text="Username" prefWidth="150.0"/>
                <TableColumn fx:id="roleColumn" text="Role" prefWidth="100.0"/>
                <TableColumn fx:id="activeColumn" text="Active" prefWidth="80.0"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <VBox spacing="10.0">
            <padding>
                <Insets top="15.0"/>
            </padding>
            <GridPane hgap="10.0" vgap="8.0">
                <Label text="Username" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="usernameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Password" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <PasswordField fx:id="passwordField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Role" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="roleComboBox" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="10.0">
                <Button fx:id="createButton" text="Create" onAction="#onCreate"/>
                <Button fx:id="updateButton" text="Update" onAction="#onUpdate"/>
                <Button fx:id="deactivateButton" text="Deactivate" onAction="#onDeactivate"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
