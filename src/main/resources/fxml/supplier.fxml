<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.supermarketpos.controller.SupplierController"
            stylesheets="@../css/dashboard.css"
            prefWidth="1280" prefHeight="800">

    <!-- ── LEFT SIDEBAR ────────────────────────────────────────────────── -->
    <left>
        <VBox styleClass="sidebar">
            <!-- Brand / Logo Header -->
            <HBox styleClass="logo-container">
                <Label text="🛒" styleClass="logo-icon"/>
                <Label text="SmartMart" styleClass="logo-text-brand"/>
                <Label text="POS" styleClass="logo-text-pos"/>
            </HBox>

            <!-- Navigation Links List -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="sidebar-scroll">
                <VBox spacing="4.0">
                    <padding><Insets top="10.0" right="12.0" bottom="10.0" left="12.0"/></padding>

                    <Button fx:id="btnDashboardNav" text="🏠  Dashboard" onAction="#onDashboard" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnNewBillNav" text="🛒  New Bill" onAction="#onNewBill" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnProductsNav" text="🏷️  Products" onAction="#onProducts" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnInventoryNav" text="📦  Inventory" onAction="#onInventory" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnPurchasesNav" text="🛍️  Purchases" onAction="#onPurchases" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnCustomersNav" text="👥  Customers" onAction="#onCustomersNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnSuppliersNav" text="🚚  Suppliers" onAction="#onSuppliersNav" styleClass="sidebar-nav-button, active" maxWidth="Infinity"/>
                    <Button fx:id="btnReportsNav" text="📊  Reports" onAction="#onReports" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnSettingsNav" text="⚙️  Settings" onAction="#onSettings" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnUsersNav" text="👤  Users" onAction="#onUsersNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                    <Button fx:id="btnBackupNav" text="💾  Backup" onAction="#onBackupNav" styleClass="sidebar-nav-button" maxWidth="Infinity"/>
                </VBox>
            </ScrollPane>

            <!-- Sidebar User Profile -->
            <VBox>
                <padding><Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/></padding>
                <HBox styleClass="sidebar-user-card" alignment="CENTER_LEFT">
                    <Label text="👤" styleClass="avatar-circle"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="loggedUserLabel" text="admin" styleClass="user-name-text"/>
                        <Label fx:id="roleLabel" text="Administrator" styleClass="user-role-text"/>
                        <Label text="🟢 Online" styleClass="status-online"/>
                    </VBox>
                    <Button fx:id="logoutButton" text="🚪 Logout" onAction="#onLogout" styleClass="btn-logout-sidebar"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- ── TOP HEADER BAR ──────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="15.0">
            <Button text="🛒" styleClass="menu-toggle-btn"/>

            <HBox styleClass="search-box">
                <Label text="🔍 " style="-fx-text-fill: #94a3b8;"/>
                <TextField fx:id="searchField" promptText="Search supplier by name / code / mobile..." styleClass="search-field" onAction="#handleSearch" HBox.hgrow="ALWAYS"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="dateLabel" text="19 Jul 2026 Sunday" styleClass="header-info-label"/>
            <Label text="|" styleClass="header-info-label" style="-fx-text-fill: #cbd5e1;"/>
            <Label fx:id="currentTimeLabel" text="01:39 PM" styleClass="header-info-label"/>
            <Button fx:id="refreshButton" text="🔄" onAction="#handleRefresh" styleClass="menu-toggle-btn"/>
            <Button text="🚪 Logout" onAction="#onLogout" styleClass="btn-logout-sidebar"/>
        </HBox>
    </top>

    <!-- ── CENTER CONTENT ─────────────────────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="sidebar-scroll">
            <VBox styleClass="dashboard-content">

                <!-- Header Title -->
                <VBox spacing="4.0">
                    <Label text="Suppliers Management" styleClass="welcome-title"/>
                    <Label text="Manage vendor contacts, GST credentials, supply lines, and purchase orders." styleClass="welcome-subtitle"/>
                </VBox>

                <!-- KPI Summary Cards -->
                <HBox spacing="16.0">
                    <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <Label text="🚚" styleClass="kpi-icon-box, kpi-icon-suppliers"/>
                        <VBox spacing="2">
                            <Label text="Total Suppliers" styleClass="kpi-title"/>
                            <Label fx:id="lblTotalSuppliers" text="0" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <Label text="🟢" styleClass="kpi-icon-box, kpi-icon-sales"/>
                        <VBox spacing="2">
                            <Label text="Active Suppliers" styleClass="kpi-title"/>
                            <Label fx:id="lblActiveSuppliers" text="0" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <Label text="🏙️" styleClass="kpi-icon-box, kpi-icon-products"/>
                        <VBox spacing="2">
                            <Label text="Supply Regions" styleClass="kpi-title"/>
                            <Label fx:id="lblCoveredCities" text="0" styleClass="kpi-value"/>
                        </VBox>
                    </HBox>
                </HBox>

                <!-- Main Content Split Pane -->
                <HBox spacing="16.0">

                    <!-- Supplier Table Area -->
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" prefWidth="720">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Supplier Directory" styleClass="card-header-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Status:" styleClass="form-label"/>
                            <ComboBox fx:id="statusFilter" onAction="#handleStatusFilterChange" promptText="All"/>
                            <Button text="🔄 Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
                        </HBox>

                        <TableView fx:id="supplierTable" prefHeight="480" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="codeColumn" text="Code" prefWidth="90.0"/>
                                <TableColumn fx:id="nameColumn" text="Supplier Name" prefWidth="170.0"/>
                                <TableColumn fx:id="contactColumn" text="Contact Person" prefWidth="130.0"/>
                                <TableColumn fx:id="mobileColumn" text="Mobile" prefWidth="110.0"/>
                                <TableColumn fx:id="emailColumn" text="Email" prefWidth="150.0"/>
                                <TableColumn fx:id="cityColumn" text="City" prefWidth="90.0"/>
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="90.0"/>
                            </columns>
                            <placeholder><Label text="No suppliers found."/></placeholder>
                        </TableView>
                    </VBox>

                    <!-- Supplier Edit / Form Card -->
                    <VBox styleClass="content-card" prefWidth="380">
                        <Label text="Supplier Details &amp; Registration" styleClass="card-header-title"/>

                        <VBox spacing="8.0">
                            <HBox spacing="8">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Supplier Code *" styleClass="form-label"/>
                                    <TextField fx:id="codeField" promptText="e.g. SUP001"/>
                                </VBox>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Contact Person" styleClass="form-label"/>
                                    <TextField fx:id="contactPersonField" promptText="Name"/>
                                </VBox>
                            </HBox>

                            <VBox spacing="4">
                                <Label text="Company / Supplier Name *" styleClass="form-label"/>
                                <TextField fx:id="nameField" promptText="Company Name"/>
                            </VBox>

                            <HBox spacing="8">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Mobile *" styleClass="form-label"/>
                                    <TextField fx:id="mobileField" promptText="9876543210"/>
                                </VBox>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Email" styleClass="form-label"/>
                                    <TextField fx:id="emailField" promptText="supplier@domain.com"/>
                                </VBox>
                            </HBox>

                            <VBox spacing="4">
                                <Label text="GST Number" styleClass="form-label"/>
                                <TextField fx:id="gstField" promptText="22AAAAA0000A1Z5"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Address" styleClass="form-label"/>
                                <TextArea fx:id="addressField" promptText="Registered office address" prefRowCount="2" wrapText="true"/>
                            </VBox>

                            <HBox spacing="8">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="City" styleClass="form-label"/>
                                    <TextField fx:id="cityField" promptText="City"/>
                                </VBox>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="State" styleClass="form-label"/>
                                    <TextField fx:id="stateField" promptText="State"/>
                                </VBox>
                                <VBox spacing="4" prefWidth="80">
                                    <Label text="Pincode" styleClass="form-label"/>
                                    <TextField fx:id="pincodeField" promptText="Zip"/>
                                </VBox>
                            </HBox>

                            <Separator style="-fx-padding: 4 0;"/>

                            <HBox spacing="8">
                                <Button fx:id="addButton" text="Add Supplier" onAction="#handleAdd" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Button fx:id="updateButton" text="Update" onAction="#handleUpdate" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            </HBox>

                            <HBox spacing="8">
                                <Button fx:id="activateButton" text="Activate" onAction="#handleActivate" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Button fx:id="deactivateButton" text="Deactivate" onAction="#handleDeactivate" styleClass="btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            </HBox>

                            <Button fx:id="purchaseHistoryButton" text="🛍️ View Purchase Orders" onAction="#handlePurchaseHistory" styleClass="btn-secondary" maxWidth="Infinity"/>
                            <Button fx:id="clearButton" text="Clear Form" onAction="#handleClear" styleClass="btn-secondary" maxWidth="Infinity"/>
                        </VBox>
                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ── FOOTER BAR ──────────────────────────────────────────────────── -->
    <bottom>
        <HBox styleClass="footer-bar" alignment="CENTER_LEFT">
            <Label text="SmartMart POS v1.0.0 — Supplier Module" styleClass="footer-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="© 2026 SmartMart POS. All rights reserved." styleClass="footer-text"/>
        </HBox>
    </bottom>
</BorderPane>