<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.supermarketpos.controller.LoginController"
            stylesheets="@../css/dashboard.css"
            style="-fx-background-color: #f1f5f9;"
            prefWidth="1280" prefHeight="800">

    <!-- ── CENTER CARD ─────────────────────────────────────────────────── -->
    <center>
        <VBox alignment="CENTER">
            <!-- Modern Login Card -->
            <VBox alignment="CENTER" spacing="20.0" prefWidth="400" maxWidth="400"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 16px; -fx-padding: 36px 32px; -fx-effect: dropshadow(gaussian, rgba(15, 23, 42, 0.08), 24, 0, 0, 8);">

                <!-- Brand Logo Header -->
                <VBox alignment="CENTER" spacing="6">
                    <HBox alignment="CENTER" spacing="8">
                        <Label text="🛒" style="-fx-font-size: 36px;"/>
                    </HBox>
                    <HBox alignment="CENTER" spacing="4">
                        <Label text="SmartMart" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <Label text="POS" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                    </HBox>
                    <Label text="Sign in to your account" style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                </VBox>

                <!-- Input Fields Section -->
                <VBox spacing="14.0" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                    <!-- Username Field -->
                    <VBox spacing="6">
                        <Label text="USERNAME" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-letter-spacing: 0.5px;"/>
                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 2px 10px;">
                            <Label text="👤" style="-fx-font-size: 14px; -fx-text-fill: #94a3b8; -fx-padding: 0 6 0 2;"/>
                            <TextField fx:id="usernameField" promptText="Enter your username" HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px; -fx-padding: 8 4;"/>
                        </HBox>
                    </VBox>

                    <!-- Password Field -->
                    <VBox spacing="6">
                        <Label text="PASSWORD" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-letter-spacing: 0.5px;"/>
                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 2px 10px;">
                            <Label text="🔒" style="-fx-font-size: 14px; -fx-text-fill: #94a3b8; -fx-padding: 0 6 0 2;"/>
                            <StackPane HBox.hgrow="ALWAYS">
                                <PasswordField fx:id="passwordField" promptText="Enter your password"
                                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px; -fx-padding: 8 4;"/>
                                <TextField fx:id="visiblePasswordField" promptText="Enter your password"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px; -fx-padding: 8 4;"/>
                            </StackPane>
                        </HBox>
                    </VBox>

                    <!-- Show Password Checkbox -->
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <CheckBox fx:id="showPasswordCheckBox" text="Show password" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                    </HBox>
                </VBox>

                <!-- Login & Action Buttons -->
                <VBox spacing="10.0" alignment="CENTER" maxWidth="Infinity">
                    <Button fx:id="loginButton" text="LOGIN" defaultButton="true" onAction="#onLogin"
                            styleClass="btn-primary" maxWidth="Infinity" style="-fx-padding: 10px; -fx-font-size: 13px; -fx-font-weight: bold;"/>

                    <Hyperlink fx:id="forgotPasswordLink" text="FORGOT PASSWORD?" onAction="#onForgotPassword"
                               style="-fx-text-fill: #2563eb; -fx-font-weight: bold; -fx-font-size: 11px; -fx-underline: false;"/>
                </VBox>

                <HBox alignment="CENTER">
                    <Button fx:id="exitButton" text="Exit Application" onAction="#onExit" styleClass="btn-secondary" style="-fx-font-size: 11px; -fx-padding: 4 12;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <!-- ── FOOTER BAR ──────────────────────────────────────────────────── -->
    <bottom>
        <HBox alignment="CENTER" spacing="16.0" style="-fx-padding: 16px;">
            <Label text="© 2026 SmartMart POS" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
            <Label text="•" style="-fx-text-fill: #cbd5e1;"/>
            <Label text="Terms of Service" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
            <Label text="•" style="-fx-text-fill: #cbd5e1;"/>
            <Label text="Privacy Policy" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
        </HBox>
    </bottom>
</BorderPane>
