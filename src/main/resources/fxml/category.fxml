<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.supermarketpos.controller.CategoryController"
            stylesheets="@../css/common.css">

    <top>
        <ToolBar>
            <items>
                <TextField fx:id="searchField" promptText="Search category..." onAction="#handleSearch"/>
                <Button text="Search" onAction="#handleSearch"/>
                <Button fx:id="refreshButton" text="Refresh" onAction="#handleRefresh"/>
            </items>
        </ToolBar>
    </top>

    <center>
        <TableView fx:id="categoryTable">
            <columns>
                <TableColumn fx:id="nameColumn" text="Name" prefWidth="200"/>
                <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="300"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <GridPane hgap="10" vgap="10">
                <Label text="Category Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Description:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextArea fx:id="descriptionField" prefRowCount="2" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="10">
                <Button fx:id="addButton" text="Add" onAction="#handleAdd"/>
                <Button fx:id="editButton" text="Edit" onAction="#handleEdit"/>
                <Button fx:id="activateButton" text="Activate" onAction="#handleActivate"/>
                <Button fx:id="deactivateButton" text="Deactivate" onAction="#handleDeactivate"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>