<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.supermarketpos.controller.DashboardController"
            stylesheets="@../css/dashboard.css" styleClass="dashboard-root">

    <top>
        <HBox styleClass="top-bar" spacing="15.0" alignment="CENTER_LEFT">
            <padding><Insets top="10.0" right="20.0" bottom="10.0" left="20.0"/></padding>
            <Label fx:id="storeNameLabel" styleClass="store-name" text="SmartMart POS"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="loggedUserLabel" styleClass="user-label"/>
            <Label fx:id="roleLabel" styleClass="role-label"/>
            <Label fx:id="currentTimeLabel" styleClass="time-label"/>
            <Button fx:id="logoutButton" text="Logout" onAction="#onLogout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20.0">
            <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/></padding>

            <HBox spacing="15.0" styleClass="cards-row">
                <VBox styleClass="dashboard-card">
                    <Label text="Today's Sales" styleClass="card-title"/>
                    <Label fx:id="todaySalesLabel" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="dashboard-card">
                    <Label text="Today's Profit" styleClass="card-title"/>
                    <Label fx:id="todayProfitLabel" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="dashboard-card">
                    <Label text="Products" styleClass="card-title"/>
                    <Label fx:id="productsCountLabel" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="dashboard-card">
                    <Label text="Customers" styleClass="card-title"/>
                    <Label fx:id="customersCountLabel" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="dashboard-card">
                    <Label text="Suppliers" styleClass="card-title"/>
                    <Label fx:id="suppliersCountLabel" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="dashboard-card low-stock-card">
                    <Label text="Low Stock" styleClass="card-title"/>
                    <Label fx:id="lowStockLabel" styleClass="card-value"/>
                </VBox>
            </HBox>

            <HBox spacing="10.0" styleClass="quick-actions-row">
                <Button fx:id="newBillButton" text="New Bill" onAction="#onNewBill"/>
                <Button fx:id="productsButton" text="Products" onAction="#onProducts"/>
                <Button fx:id="inventoryButton" text="Inventory" onAction="#onInventory"/>
                <Button fx:id="purchasesButton" text="Purchases" onAction="#onPurchases"/>
                <Button fx:id="reportsButton" text="Reports" onAction="#onReports"/>
                <Button fx:id="settingsButton" text="Settings" onAction="#onSettings"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh"/>
            </HBox>

            <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                <Label text="Recent Bills" styleClass="section-title"/>
                <TableView fx:id="recentBillsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="invoiceColumn" text="Invoice Number" prefWidth="150.0"/>
                        <TableColumn fx:id="customerColumn" text="Customer" prefWidth="150.0"/>
                        <TableColumn fx:id="amountColumn" text="Amount" prefWidth="100.0"/>
                        <TableColumn fx:id="paymentTypeColumn" text="Payment Type" prefWidth="120.0"/>
                        <TableColumn fx:id="dateColumn" text="Date" prefWidth="160.0"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" styleClass="bottom-bar">
            <padding><Insets top="5.0" right="15.0" bottom="5.0" left="15.0"/></padding>
            <Label fx:id="appVersionLabel" styleClass="version-label"/>
        </HBox>
    </bottom>
</BorderPane>